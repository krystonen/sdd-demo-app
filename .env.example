VITE_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
VITE_SHOPIFY_STOREFRONT_TOKEN=your_storefront_access_token
VITE_SHOPIFY_BOOKS_COLLECTION=books
# Optional: Formspree instead of /api/contact
# 1. formspree.io → + New form → copy the 8-char ID from the endpoint URL
# 2. NOT your email — use the hash only, e.g. https://formspree.io/f/xjvnoqab
# VITE_CONTACT_FORM_ENDPOINT=https://formspree.io/f/your_form_id
